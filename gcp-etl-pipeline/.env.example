# Copy to .env and fill in values before deploying
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1

# GCS
GCS_BUCKET_NAME=your-project-id-etl-pipeline

# Cloud Tasks
TASK_QUEUE_NAME=etl-scrape-queue

# Set automatically by deploy.sh after Cloud Run & Cloud Function are deployed
FUNCTION_URL=https://REGION-PROJECT_ID.cloudfunctions.net/etl-process-page
PIPELINE_SA_EMAIL=etl-pipeline-sa@your-project-id.iam.gserviceaccount.com

# Scraper settings
SCRAPE_BASE_URL=https://quotes.toscrape.com
MAX_PAGES=10
