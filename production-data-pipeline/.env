# ── Copy to .env and fill in real values ──────────────────────────────────────
# cp config/env.example .env

# ── Airflow ────────────────────────────────────────────────────────────────────
AIRFLOW__CORE__FERNET_KEY=change_me_generate_with_python_-c_from_cryptography_fernet
AIRFLOW__CORE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres:5432/airflow
AIRFLOW__CELERY__RESULT_BACKEND=db+postgresql://airflow:airflow@postgres:5432/airflow
AIRFLOW__CELERY__BROKER_URL=redis://:@redis:6379/0
AIRFLOW__WEBSERVER__SECRET_KEY=change_me_random_32_char_string
AIRFLOW_UID=50000

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# ── MinIO (local S3) ───────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://minio:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1

# ── Kafka ──────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_EVENTS=raw_events
KAFKA_TOPIC_TRANSACTIONS=raw_transactions
KAFKA_CONSUMER_GROUP=pipeline_consumer

# ── Snowflake (production only) ────────────────────────────────────────────────
SNOWFLAKE_ACCOUNT=your_account.us-east-1
SNOWFLAKE_USER=pipeline_user
SNOWFLAKE_PASSWORD=change_me
SNOWFLAKE_DATABASE=DATA_WAREHOUSE
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_WAREHOUSE=PIPELINE_WH
SNOWFLAKE_ROLE=PIPELINE_ROLE

# ── Spark ──────────────────────────────────────────────────────────────────────
SPARK_MASTER_URL=spark://spark-master:7077
SPARK_DRIVER_MEMORY=2g
SPARK_EXECUTOR_MEMORY=4g
SPARK_EXECUTOR_CORES=2

# ── Monitoring ─────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/CHANGE/ME
PROMETHEUS_PUSHGATEWAY_URL=http://prometheus:9091
GRAFANA_ADMIN_PASSWORD=admin

# ── Pipeline ───────────────────────────────────────────────────────────────────
PIPELINE_ENV=local          # local | staging | production
PIPELINE_LOG_LEVEL=INFO
PIPELINE_MAX_PARALLEL_SOURCES=10
PIPELINE_QUALITY_THRESHOLD=0.95
DATA_LAKE_PATH=/data/lake   # s3://your-bucket/lake in production
